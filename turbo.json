{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "compile": {
      "outputs": ["artifacts/**", "cache/**"]
    },
    "deploy": {
      "dependsOn": ["compile"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}